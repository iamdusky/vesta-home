# ── LLM backend ───────────────────────────────────────────────────────────
#
# Option A — Ollama (easiest, runs on any machine)
#   Install: https://ollama.com
#   Run:     ollama serve && ollama pull llama3.2
#
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=none
MODEL=llama3.2

#
# Option B — OpenAI API (no local GPU required)
#
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# MODEL=gpt-4o-mini

#
# Option C — vLLM (local GPU, best quality + tool use)
#   Run:  vllm serve NousResearch/Hermes-4.3-36B \
#           --port 8000 --enable-auto-tool-choice --tool-call-parser hermes
#
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=none
# MODEL=NousResearch/Hermes-4.3-36B

# ── Plex (optional) ───────────────────────────────────────────────────────
# Required only if you want Plex recommendations on the board.
# To find your token: Settings → Troubleshooting → "Show Plex token" in Plex web UI.
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_plex_token_here

# ── Vestaboard ────────────────────────────────────────────────────────────
# Read/Write API token — generate one at https://web.vestaboard.com → Settings → API
VESTABOARD_TOKEN=your_token_here

# API URL (usually leave this as-is)
# Cloud (default):  https://rw.vestaboard.com/
# Local API:        http://<board-ip>/   (if you have local API access)
VESTABOARD_API_URL=https://rw.vestaboard.com/
